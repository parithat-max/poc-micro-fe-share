  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "tsup": "^8",
    "typescript": "^5"
  }
}
